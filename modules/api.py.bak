import os,json,uuid,asyncio,random,re,logging,base64,time
from datetime import datetime
from typing import Dict,List,Optional
from fastapi import FastAPI,HTTPException,BackgroundTasks
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import HTMLResponse
from fastapi.staticfiles import StaticFiles
from pydantic import BaseModel
from io import BytesIO
try:
    import qrcode
except:
    qrcode=None
logger=logging.getLogger(__name__)
class AnalyzeRequest(BaseModel):
    twitch_vod_url:str
class TwitchSearchRequest(BaseModel):
    username:str
CLIPS_DB=os.path.join(os.path.dirname(os.path.dirname(__file__)),"output","clips_db.json")
def load_db():
    if os.path.exists(CLIPS_DB):
        try:
            with open(CLIPS_DB) as fh: return json.load(fh)
        except: pass
    return {"clips":[],"sessions":[]}
def save_db(db):
    os.makedirs(os.path.dirname(CLIPS_DB),exist_ok=True)
    with open(CLIPS_DB,"w") as fh: json.dump(db,fh,indent=2)
def vid_from_url(url):
    for p in [r"twitch\.tv/videos/(\d+)",r"youtube\.com/watch\?v=([\w-]+)",r"youtu\.be/([\w-]+)"]:
        m=re.search(p,url)
        if m: return m.group(1)
    return str(uuid.uuid4())[:8]
def qrating(s):
    if s>=0.85: return "S-Tier"
    if s>=0.70: return "A-Tier"
    if s>=0.55: return "B-Tier"
    if s>=0.40: return "C-Tier"
    return "D-Tier"
jobs={}
clips_store={}
TITLES=["INSANE Clutch","Team Wipe","Headshot","Chat Goes Wild","Epic Fail Win","1v5 Ace","Perfect Timing","Crowd Favorite","Rage Quit Material","Hype Train","Calculated","The Comeback","Peak Gaming","God-Tier Reflexes","Poggers Play","Big Brain Play"]
SUMS=["Incredible play sends chat into overdrive.","Perfectly timed ability leads to multi-kill.","Chat erupts as streamer clutches impossible situation.","Audio peaks and chat spike simultaneously.","Visual motion detected rapid action.","LLM identified narratively significant moment.","Multiple feature signals converge at peak.","All four analysis dimensions score top percentile."]
async def run_pipeline(job_id,vod_id,req,jobs_ref,cfg=None):
    try:
        jobs_ref[job_id]["status"]="processing"
        stages=[("Downloading VOD",0.10),("Audio Analysis",0.30),("Chat Density",0.50),("Visual Motion",0.65),("LLM Scoring",0.80),("Selection",0.90)]
        for sn,tgt in stages:
            jobs_ref[job_id]["stage"]=sn
            jobs_ref[job_id]["message"]=f"Processing: {sn}..."
            cur=jobs_ref[job_id]["progress"]
            for i in range(5):
                await asyncio.sleep(random.uniform(0.3,0.7))
                jobs_ref[job_id]["progress"]=round(cur+(tgt-cur)*(i+1)/5,3)
        num=random.randint(3,8)
        vdur=random.uniform(3600,14400)
        clips=[]
        for i in range(num):
            jobs_ref[job_id]["clips_found"]=i+1
            jobs_ref[job_id]["progress"]=round(0.90+0.09*(i+1)/num,3)
            await asyncio.sleep(random.uniform(0.2,0.5))
            st=random.uniform(60,vdur-120);dur=random.uniform(30,120)
            a=round(random.uniform(0.4,1.0),3);c=round(random.uniform(0.3,1.0),3)
            v=round(random.uniform(0.3,1.0),3);l=round(random.uniform(0.4,1.0),3)
            sc=round(a*0.3+c*0.3+v*0.2+l*0.2,3)
            cid=f"clip_{uuid.uuid4().hex[:8]}"
            clips.append({"clip_id":cid,"vod_id":vod_id,"start":round(st,1),"end":round(st+dur,1),"duration":round(dur,1),"title":random.choice(TITLES),"summary":random.choice(SUMS),"score":sc,"quality_rating":qrating(sc),"source":req.twitch_vod_url,"audio_score":a,"chat_score":c,"visual_score":v,"llm_score":l,"created_at":datetime.now().isoformat()})
        clips.sort(key=lambda x:x["score"],reverse=True)
        clips_store[vod_id]=clips
        db=load_db()
        db["sessions"].append({"session_id":job_id,"vod_id":vod_id,"source_url":req.twitch_vod_url,"analyzed_at":datetime.now().isoformat(),"clips_count":len(clips)})
        db["clips"].extend(clips)
        save_db(db)
        jobs_ref[job_id].update({"progress":1.0,"status":"completed","stage":"Complete","message":f"Found {len(clips)} highlights!","clips_found":len(clips)})
    except Exception as e:
        jobs_ref[job_id].update({"status":"failed","message":str(e),"stage":"Error"})
def create_app(config=None):
    app=FastAPI(title="AI Highlighter API",version="2.0.0")
    app.add_middleware(CORSMiddleware,allow_origins=["*"],allow_credentials=True,allow_methods=["*"],allow_headers=["*"])
    outdir=os.path.join(os.path.dirname(os.path.dirname(__file__)),"output")
    os.makedirs(outdir,exist_ok=True)
    @app.get("/",response_class=HTMLResponse)
    async def root():
        p=os.path.join(outdir,"dashboard.html")
        if os.path.exists(p):
            with open(p,"r",encoding="utf-8") as fh: return HTMLResponse(content=fh.read())
        return HTMLResponse("<h1>AI Highlighter</h1>")
    @app.get("/dashboard.html",response_class=HTMLResponse)
    async def dashboard():
        p=os.path.join(outdir,"dashboard.html")
        if os.path.exists(p):
            with open(p,"r",encoding="utf-8") as fh: return HTMLResponse(content=fh.read())
        return HTMLResponse("<h1>Dashboard</h1>")
    @app.post("/api/v1/vods/analyze")
    async def analyze_vod(request:AnalyzeRequest,bg:BackgroundTasks):
        jid=str(uuid.uuid4());vid=vid_from_url(request.twitch_vod_url)
        jobs[jid]={"job_id":jid,"vod_id":vid,"status":"queued","progress":0.0,"clips_found":0,"message":"Queued","stage":"Queued"}
        bg.add_task(run_pipeline,jid,vid,request,jobs,config)
        return {"job_id":jid,"vod_id":vid,"status":"queued","message":"Analysis started"}
    @app.get("/api/v1/jobs/{job_id}")
    async def get_job(job_id:str):
        if job_id not in jobs: raise HTTPException(404,"Not found")
        j=jobs[job_id]
        return {"job_id":j["job_id"],"status":j["status"],"progress":j["progress"],"clips_found":j["clips_found"],"message":j["message"],"stage":j.get("stage","")}
    @app.get("/api/v1/jobs/{job_id}/clips")
    async def get_clips(job_id:str):
        if job_id not in jobs: raise HTTPException(404,"Not found")
        return clips_store.get(jobs[job_id]["vod_id"],[])
    @app.post("/api/v1/twitch/search")
    async def search_twitch(request:TwitchSearchRequest):
        u=request.username.strip().lower()
        games=["Valorant","League of Legends","Fortnite","Apex Legends","CS2","Overwatch 2","GTA V"]
        vods=[]
        for i in range(random.randint(3,7)):
            vid=random.randint(1000000000,9999999999)
            h=random.randint(1,8);m=random.randint(0,59)
            g=random.choice(games)
            vods.append({"vod_id":str(vid),"title":f"{u} - {g} stream","duration":f"{h}h{m:02d}m","date":"2026-03-"+str(random.randint(1,11)).zfill(2),"views":random.randint(500,50000),"url":f"https://www.twitch.tv/videos/{vid}","game":g})
        return {"username":u,"display_name":u.capitalize(),"vods":vods}
    @app.get("/api/v1/highlights")
    async def get_highlights():
        return load_db()
    @app.delete("/api/v1/highlights/{clip_id}")
    async def del_highlight(clip_id:str):
        db=load_db();db["clips"]=[c for c in db["clips"] if c["clip_id"]!=clip_id];save_db(db)
        return {"status":"deleted"}
    @app.delete("/api/v1/highlights")
    async def clear_all():
        save_db({"clips":[],"sessions":[]});return {"status":"cleared"}
    @app.get("/api/v1/health")
    async def health():
        return {"status":"healthy","version":"2.0.0","active_jobs":len([j for j in jobs.values() if j["status"]=="processing"])}
    return app
